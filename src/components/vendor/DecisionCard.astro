---
import type { Vendor } from "../../lib/vendors";
import {
  DECISION_COMPLIANCE_CHECKLIST,
  vendorMeetsCompliance,
  getPriceBand,
  getDecisionPriceLabel,
} from "../../lib/vendors";
import siteConfig from "../../../site.config";
import Check from "phosphor-astro/Check.astro";
import X from "phosphor-astro/X.astro";

interface Props {
  vendor: Vendor;
  verdict?: string;
  bestFor: string;
  avoidIf: string;
  integrationComplexity: "Low" | "Medium" | "High";
}

const { vendor, verdict, bestFor, avoidIf, integrationComplexity } = Astro.props;

const priceBand = getPriceBand(vendor);
const priceLabel = getDecisionPriceLabel(vendor);

const integrationTone = {
  Low: "text-emerald-700 dark:text-emerald-400 bg-emerald-50 dark:bg-emerald-950/30 border-emerald-200 dark:border-emerald-900",
  Medium: "text-amber-700 dark:text-amber-400 bg-amber-50 dark:bg-amber-950/30 border-amber-200 dark:border-amber-900",
  High: "text-zinc-700 dark:text-zinc-300 bg-zinc-100 dark:bg-zinc-800 border-zinc-200 dark:border-zinc-700",
}[integrationComplexity];

const tallyFormId = siteConfig.monetization.tallyFormId;
const showTallyCta = vendor.featured && !!tallyFormId;

const complianceRow = DECISION_COMPLIANCE_CHECKLIST.map((item) => ({
  label: item.label,
  met: vendorMeetsCompliance(vendor, item.keys),
}));
---

<section
  class="rounded-lg border border-zinc-200 dark:border-zinc-700 bg-white dark:bg-zinc-900 overflow-hidden mb-6"
  aria-label={`${vendor.name} verdict and fit summary`}
>
  {verdict && (
    <div class="px-6 py-5 border-b border-zinc-100 dark:border-zinc-800">
      <p class="text-lg leading-snug text-zinc-900 dark:text-zinc-100">
        {verdict}
      </p>
    </div>
  )}

  <div class="grid sm:grid-cols-2 divide-y sm:divide-y-0 sm:divide-x divide-zinc-100 dark:divide-zinc-800">
    <div class="px-6 py-5">
      <p class="text-xs uppercase tracking-wide text-emerald-700 dark:text-emerald-400 font-medium mb-2">
        Best For
      </p>
      <p class="text-sm text-zinc-700 dark:text-zinc-300 leading-relaxed">
        {bestFor}
      </p>
    </div>
    <div class="px-6 py-5">
      <p class="text-xs uppercase tracking-wide text-zinc-500 dark:text-zinc-400 font-medium mb-2">
        Avoid If
      </p>
      <p class="text-sm text-zinc-700 dark:text-zinc-300 leading-relaxed">
        {avoidIf}
      </p>
    </div>
  </div>

  <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 px-6 py-4 border-t border-zinc-100 dark:border-zinc-800 bg-zinc-50/60 dark:bg-zinc-950/40">
    <div>
      <p class="text-[11px] uppercase tracking-wide text-zinc-500 dark:text-zinc-400">Price</p>
      <p class="text-sm font-mono text-zinc-900 dark:text-zinc-100 mt-0.5">
        {priceBand && <span class="text-blue-600 dark:text-blue-400 mr-1.5">{priceBand}</span>}
        <span class="text-zinc-700 dark:text-zinc-300">{priceLabel}</span>
      </p>
    </div>
    <div>
      <p class="text-[11px] uppercase tracking-wide text-zinc-500 dark:text-zinc-400">Integration</p>
      <span
        class={`inline-flex items-center mt-1 px-2 py-0.5 text-xs font-medium rounded-md border ${integrationTone}`}
      >
        {integrationComplexity}
      </span>
    </div>
    {vendor.has_free_trial && (
      <div>
        <p class="text-[11px] uppercase tracking-wide text-zinc-500 dark:text-zinc-400">Trial</p>
        <p class="text-sm text-emerald-700 dark:text-emerald-400 mt-0.5">Free trial available</p>
      </div>
    )}
  </div>

  <div class="px-6 py-4 border-t border-zinc-100 dark:border-zinc-800">
    <p class="text-[11px] uppercase tracking-wide text-zinc-500 dark:text-zinc-400 mb-2">
      Compliance
    </p>
    <ul class="flex flex-wrap gap-x-4 gap-y-2">
      {complianceRow.map((item) => (
        <li class="flex items-center gap-1.5 text-sm">
          {item.met ? (
            <Check
              class="w-4 h-4 text-emerald-600 dark:text-emerald-400 shrink-0"
              aria-hidden="true"
              weight="bold"
            />
          ) : (
            <X
              class="w-4 h-4 text-zinc-400 dark:text-zinc-600 shrink-0"
              aria-hidden="true"
            />
          )}
          <span class={item.met ? "text-zinc-800 dark:text-zinc-200" : "text-zinc-400 dark:text-zinc-600 line-through"}>
            {item.label}
          </span>
        </li>
      ))}
    </ul>
  </div>

  <div class="px-6 py-4 border-t border-zinc-100 dark:border-zinc-800 flex flex-wrap items-center justify-between gap-3">
    <p class="text-xs text-zinc-500 dark:text-zinc-400">
      {showTallyCta ? "Featured partner — request a tailored quote" : "Direct link to vendor website"}
    </p>
    {showTallyCta ? (
      <button
        type="button"
        data-tally-open={tallyFormId}
        data-tally-overlay="1"
        data-tally-hide-title="1"
        data-tally-vendor={vendor.name}
        class="inline-flex items-center justify-center px-4 py-2 rounded-md text-sm font-medium bg-blue-600 text-white hover:bg-blue-700 transition-colors"
      >
        Get a Quote
      </button>
    ) : (
      <a
        href={`/go/${vendor.slug}`}
        rel="nofollow noopener"
        target="_blank"
        class="inline-flex items-center justify-center px-4 py-2 rounded-md text-sm font-medium border border-zinc-300 dark:border-zinc-600 text-zinc-900 dark:text-zinc-100 hover:border-blue-400 dark:hover:border-blue-500 transition-colors"
      >
        Visit Website
      </a>
    )}
  </div>
</section>
