---
import { Calculator, ArrowRight } from "@phosphor-icons/react";
---

<section class="border-t border-zinc-200 dark:border-zinc-700">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-12 md:py-16">
    <div class="rounded-lg border border-blue-200 dark:border-blue-600/30 bg-blue-50/50 dark:bg-blue-950/10 p-6 md:p-8 flex flex-col md:flex-row md:items-center md:justify-between gap-6">
      <div class="flex items-start gap-4 md:max-w-2xl">
        <div class="hidden md:flex shrink-0 size-10 items-center justify-center rounded-md bg-blue-100 dark:bg-blue-900/30">
          <Calculator size={20} weight="regular" className="text-blue-600 dark:text-blue-400" />
        </div>
        <div>
          <h2 class="text-xl md:text-2xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-100">
            Calculate Your KYC Verification Costs Instantly
          </h2>
          <p class="mt-2 text-sm md:text-base text-zinc-600 dark:text-zinc-400 leading-relaxed">
            Compare live pricing models across 24+ KYC vendors based on your
            business volume. Side-by-side cost breakdown in seconds.
          </p>
        </div>
      </div>
      <a
        href="/tools/kyc-cost-calculator"
        class="inline-flex items-center justify-center gap-2 rounded-md bg-blue-600 hover:bg-blue-700 px-5 py-2.5 text-sm font-medium text-white transition-colors shrink-0"
      >
        Try KYC Cost Calculator
        <ArrowRight size={16} weight="bold" />
      </a>
    </div>
  </div>
</section>
