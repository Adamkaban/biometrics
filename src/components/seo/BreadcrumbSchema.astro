---
import siteConfig from "../../../site.config";

export interface BreadcrumbItem {
  name: string;
  url: string;
}

export interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;

const toAbsolute = (url: string) =>
  url.startsWith("http")
    ? url
    : new URL(url, siteConfig.seo.siteUrl).toString();

const schema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: items.map((item, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: item.name,
    item: toAbsolute(item.url),
  })),
};
---

<nav aria-label="Breadcrumb" class="text-sm text-zinc-500 dark:text-zinc-400">
  <ol class="flex flex-wrap items-center gap-1">
    {
      items.map((item, i) => (
        <li class="flex items-center gap-1">
          {i > 0 && <span aria-hidden="true">/</span>}
          {i === items.length - 1 ? (
            <span aria-current="page" class="text-zinc-900 dark:text-zinc-100">
              {item.name}
            </span>
          ) : (
            <a href={item.url} class="hover:text-zinc-900 dark:hover:text-zinc-100 underline-offset-2 hover:underline">
              {item.name}
            </a>
          )}
        </li>
      ))
    }
  </ol>
</nav>

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
