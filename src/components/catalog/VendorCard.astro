---
import {
  CARD_COMPLIANCE_ORDER,
  COMPLIANCE_LABELS,
  getActiveComplianceFlags,
  getCoverageLabel,
  getSourceAttribution,
  getValueTierLabel,
  getVendorIndustries,
  pickComplianceFlags,
  type Vendor,
} from "../../lib/vendors";

interface Props {
  vendor: Vendor;
  bestForSnippet?: string;
}

const { vendor, bestForSnippet } = Astro.props;

const primaryCategory = vendor.primary_category ?? vendor.categories[0] ?? "";
const cardClass = vendor.featured
  ? "border border-blue-200 bg-blue-50/50 dark:border-blue-600/30 dark:bg-blue-950/10"
  : "border border-zinc-200 bg-white dark:border-zinc-700 dark:bg-zinc-900";
const topCompliance = pickComplianceFlags(vendor, CARD_COMPLIANCE_ORDER, 3);
const coverage = getCoverageLabel(vendor);
const valueTier = getValueTierLabel(vendor);
const sourceAttribution = getSourceAttribution(vendor);
const sdkTokens = (vendor.sdk_types ?? []).join(",");
const complianceTokens = getActiveComplianceFlags(vendor).join(",");
const industryTokens = getVendorIndustries(vendor).join(",");

// 10+ reviews → full trust signal; 1-9 → muted, no star; 0 → hidden
const hasHighConfidenceRating = vendor.rating > 0 && vendor.reviews_count >= 10;
const hasLowConfidenceRating = vendor.rating > 0 && vendor.reviews_count > 0 && vendor.reviews_count < 10;

// Text fallback when no concrete price — strip the redundant tier info
const pricingDisplay = vendor.starting_price === null
  ? vendor.value_tier === "enterprise"
    ? "Contact sales"
    : vendor.value_tier === "mid"
    ? "Pricing on request"
    : "Custom pricing"
  : (vendor.pricing_summary || vendor.pricing);

// Only show specific regional/country coverage — suppress all "Global" claims (baseline for IDV)
const showCoverage = coverage && !vendor.global_claim;
---

<a
  href={`/vendors/${vendor.slug}`}
  data-vendor
  data-categories={vendor.categories.join(",")}
  data-rating={vendor.rating}
  data-trial={vendor.has_free_trial}
  data-name={vendor.name}
  data-featured={vendor.featured}
  data-pricing-model={vendor.pricing_model}
  data-value-tier={vendor.value_tier ?? ""}
  data-region={vendor.region ?? ""}
  data-sdks={sdkTokens}
  data-compliance={complianceTokens}
  data-industries={industryTokens}
  data-global={vendor.global_claim}
  class={`flex flex-col gap-3 rounded-lg p-5 min-h-[420px] hover:shadow-md transition-shadow no-underline ${cardClass}`}
>
  <!-- Logo + name + Featured pill -->
  <div class="flex items-center justify-between gap-3">
    <div class="flex items-center gap-3 min-w-0">
      <div class="shrink-0 w-8 h-8">
        <img
          src={vendor.logo_url || "/favicon.svg"}
          alt={`${vendor.name} logo`}
          title={`${vendor.name} logo`}
          width="32"
          height="32"
          loading="lazy"
          decoding="async"
          class="w-8 h-8 rounded object-contain"
        />
      </div>
      <span class="text-base font-semibold text-zinc-900 dark:text-zinc-100 truncate">
        {vendor.name}
      </span>
    </div>
    {vendor.featured && (
      <span class="shrink-0 text-xs font-medium bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400 rounded-full px-2 py-0.5">
        Featured
      </span>
    )}
  </div>

  <!-- Rating: high-confidence (10+ reviews) → amber star + tooltip -->
  {hasHighConfidenceRating && (
    <div class="flex items-baseline gap-1.5">
      <span
        class="group relative inline-flex items-baseline gap-1 cursor-help"
        title={sourceAttribution}
      >
        <span class="text-sm font-mono font-semibold text-zinc-900 dark:text-zinc-100">
          {vendor.rating.toFixed(1)}
        </span>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
             class="w-3.5 h-3.5 text-amber-500" aria-hidden="true">
          <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
        </svg>
        <span
          role="tooltip"
          class="pointer-events-none absolute left-0 -top-8 z-10 whitespace-nowrap rounded-md bg-zinc-900 px-2 py-1 text-xs font-normal text-white opacity-0 transition-opacity group-hover:opacity-100 group-focus-within:opacity-100 dark:bg-zinc-100 dark:text-zinc-900"
        >
          {sourceAttribution}
        </span>
      </span>
      <span class="text-xs text-zinc-500">
        ({vendor.reviews_count.toLocaleString()} {vendor.reviews_count === 1 ? "review" : "reviews"})
      </span>
    </div>
  )}

  <!-- Rating: low-confidence (1-9 reviews) → muted text, no star -->
  {hasLowConfidenceRating && (
    <div class="flex items-baseline gap-1">
      <span class="text-sm font-mono text-zinc-400 dark:text-zinc-500">
        {vendor.rating.toFixed(1)}
      </span>
      <span class="text-xs text-zinc-400 dark:text-zinc-500">
        · {vendor.reviews_count} {vendor.reviews_count === 1 ? "review" : "reviews"}
      </span>
    </div>
  )}

  <!-- Category badge -->
  {primaryCategory && (
    <div>
      <span class="text-xs bg-zinc-100 text-zinc-600 dark:bg-zinc-800 dark:text-zinc-400 rounded-full px-2 py-0.5">
        {primaryCategory}
      </span>
    </div>
  )}

  <!-- Description — prefers B2B tagline, falls back to scraped description -->
  {(vendor.tagline || vendor.description) && (
    <p class="line-clamp-2 text-sm text-zinc-600 dark:text-zinc-400 leading-relaxed">
      {vendor.tagline ?? vendor.description}
    </p>
  )}

  {bestForSnippet && (
    <div class="pl-3 border-l-2 border-blue-400 dark:border-blue-600">
      <p class="line-clamp-2 text-sm text-zinc-900 dark:text-zinc-100 leading-snug">
        <span class="text-xs font-semibold text-blue-600 dark:text-blue-400 uppercase tracking-wide">Best for: </span>{bestForSnippet}
      </p>
    </div>
  )}

  <!-- Compliance pills — blue trust signal, shield icon (max 3, prestige-ordered) -->
  {topCompliance.length > 0 && (
    <div class="flex flex-wrap gap-1">
      {topCompliance.map(k => (
        <span class="inline-flex items-center gap-1 rounded-full border border-blue-100 bg-blue-50 px-2 py-0.5 text-xs text-blue-700 dark:border-blue-900/40 dark:bg-blue-950/20 dark:text-blue-400">
          <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true">
            <path d="M208 40H48a16 16 0 0 0-16 16v58.7c0 89.4 75.8 119.1 91 124.1a15.3 15.3 0 0 0 10 0c15.2-5 91-34.7 91-124.1V56a16 16 0 0 0-16-16Zm-30.3 78.7-56 56a8 8 0 0 1-11.4 0l-24-24a8 8 0 0 1 11.4-11.4L116 157.7l50.3-50.4a8 8 0 0 1 11.4 11.4Z"/>
          </svg>
          {COMPLIANCE_LABELS[k]}
        </span>
      ))}
    </div>
  )}

  <!-- Coverage — only when it's more than just "Global" -->
  {showCoverage && (
    <p class="inline-flex items-center gap-1 text-xs text-zinc-500 dark:text-zinc-400">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="10"/>
        <line x1="2" y1="12" x2="22" y2="12"/>
        <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
      </svg>
      {coverage}
    </p>
  )}

  <!-- Pricing — full width, no truncation risk -->
  <p class={`text-sm text-zinc-700 dark:text-zinc-300${vendor.starting_price !== null ? " font-mono" : ""}`}>
    {pricingDisplay}
  </p>

  <!-- Tier + free trial — separate row, left-aligned -->
  {(vendor.starting_price !== null && valueTier || vendor.has_free_trial) && (
    <div class="flex flex-wrap items-center gap-1">
      {vendor.starting_price !== null && valueTier && (
        <span class="text-xs rounded-full bg-zinc-100 dark:bg-zinc-800 px-2 py-0.5 text-zinc-600 dark:text-zinc-400">
          {valueTier}
        </span>
      )}
      {vendor.has_free_trial && (
        <span class="inline-flex items-center gap-1 rounded-full bg-emerald-50 px-2 py-0.5 text-xs text-emerald-700 dark:bg-emerald-950/30 dark:text-emerald-400">
          <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true">
            <path d="m229.66 77.66-128 128a8 8 0 0 1-11.32 0l-56-56a8 8 0 0 1 11.32-11.32L96 188.69 218.34 66.34a8 8 0 0 1 11.32 11.32Z"/>
          </svg>
          Free trial
        </span>
      )}
    </div>
  )}

  <!-- CTA -->
  {vendor.featured ? (
    <span class="w-full bg-blue-600 text-white rounded-md px-4 py-2 text-sm font-medium hover:bg-blue-700 transition-colors text-center block mt-auto">
      Get Quote
    </span>
  ) : (
    <span class="w-full border border-zinc-300 dark:border-zinc-600 text-zinc-800 dark:text-zinc-200 rounded-md px-4 py-2 text-sm font-medium hover:bg-zinc-50 dark:hover:bg-zinc-800 transition-colors text-center block mt-auto">
      View Profile
    </span>
  )}
</a>
