---
import type { Vendor } from "../../lib/vendors";

interface Props {
  vendor: Vendor;
}

const { vendor } = Astro.props;

const primaryCategory = vendor.categories[0] ?? "";
const cardClass = vendor.featured
  ? "border border-blue-200 bg-blue-50/50 dark:border-blue-600/30 dark:bg-blue-950/10"
  : "border border-zinc-200 bg-white dark:border-zinc-700 dark:bg-zinc-900";
---

<a
  href={`/vendors/${vendor.slug}`}
  data-vendor
  data-categories={vendor.categories.join(",")}
  data-rating={vendor.rating}
  data-trial={vendor.has_free_trial}
  data-name={vendor.name}
  data-reviews={vendor.reviews_count}
  data-featured={vendor.featured}
  class={`flex flex-col gap-4 rounded-lg p-5 hover:shadow-md transition-shadow no-underline ${cardClass}`}
>
  <!-- Logo row -->
  <div class="flex items-center justify-between gap-3">
    <div class="flex items-center gap-3 min-w-0">
      <div class="shrink-0 w-8 h-8">
        <img
          src={vendor.logo_url || "/favicon.svg"}
          alt={`${vendor.name} logo`}
          width="32"
          height="32"
          loading="lazy"
          decoding="async"
          class="w-8 h-8 rounded object-contain"
        />
      </div>
      <span class="text-sm font-semibold text-zinc-900 dark:text-zinc-100 truncate">
        {vendor.name}
      </span>
    </div>
    {vendor.featured && (
      <span class="shrink-0 text-xs font-medium bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400 rounded-full px-2 py-0.5">
        Featured
      </span>
    )}
  </div>

  <!-- Category badge -->
  {primaryCategory && (
    <div>
      <span class="text-xs bg-zinc-100 text-zinc-600 dark:bg-zinc-800 dark:text-zinc-400 rounded-full px-2 py-0.5">
        {primaryCategory}
      </span>
    </div>
  )}

  <!-- Rating row -->
  <div class="flex items-baseline gap-2">
    <span class="text-2xl font-mono font-semibold text-zinc-900 dark:text-zinc-100">
      {vendor.rating.toFixed(1)}
    </span>
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="currentColor"
      class="w-4 h-4 text-amber-500 shrink-0"
      aria-hidden="true"
    >
      <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" />
    </svg>
    <span class="text-sm text-zinc-500">
      {vendor.reviews_count.toLocaleString()} reviews
    </span>
  </div>

  <!-- Pricing -->
  <p class="text-sm text-zinc-600 dark:text-zinc-400 font-mono truncate">
    {vendor.pricing}
  </p>

  <!-- CTA button -->
  {vendor.featured ? (
    <span class="w-full bg-blue-600 text-white rounded-md px-4 py-2 text-sm font-medium hover:bg-blue-700 transition-colors text-center block mt-auto">
      Get Quote
    </span>
  ) : (
    <span class="w-full border border-zinc-200 dark:border-zinc-700 text-zinc-700 dark:text-zinc-300 rounded-md px-4 py-2 text-sm font-medium hover:bg-zinc-50 dark:hover:bg-zinc-800 transition-colors text-center block mt-auto">
      View Profile
    </span>
  )}
</a>
