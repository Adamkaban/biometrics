---
import BaseLayout from "../layouts/BaseLayout.astro";
import VendorCard from "../components/catalog/VendorCard.astro";
import HeroSearch from "../components/catalog/HeroSearch";
import HomeExpertText from "../components/home/HomeExpertText.astro";
import CalculatorCTA from "../components/home/CalculatorCTA.astro";
import { vendors, getCategorySlug, categories, CATEGORY_SLUGS } from "../lib/vendors";
import { getCollection } from "astro:content";
import {
  IdentificationCard,
  ShieldCheck,
  Fingerprint,
  CurrencyDollar,
  ShieldWarning,
} from "@phosphor-icons/react";

// Top 6 vendors by review count (highest brand search demand)
const topVendors = [...vendors]
  .sort((a, b) => b.reviews_count - a.reviews_count)
  .slice(0, 6);

// Category metadata with Phosphor icon components
const categoryData = [
  { name: "Identity Verification",    Icon: IdentificationCard },
  { name: "KYC Compliance",           Icon: ShieldCheck },
  { name: "Biometric Authentication", Icon: Fingerprint },
  { name: "AML",                      Icon: CurrencyDollar },
  { name: "Fraud Prevention",         Icon: ShieldWarning },
].map((c) => ({
  ...c,
  slug:  getCategorySlug(c.name),
  count: vendors.filter((v) => v.categories.includes(c.name)).length,
}));

// FAQ stats — computed once, used in homepage FAQ answers
const gdprCount = vendors.filter((v) => v.compliance_flags?.gdpr).length;
const publishedPricingCount = vendors.filter((v) => {
  const p = (v.pricing ?? "").toLowerCase();
  return !p.includes("contact") && !p.includes("custom") && !p.includes("request") && p.trim() !== "";
}).length;

// Lightweight data for HeroSearch island
const searchVendors = vendors.map((v) => ({ name: v.name, slug: v.slug }));
const searchCategories = Object.entries(CATEGORY_SLUGS).map(([name, slug]) => ({ name, slug }));

// Blog preview — empty on launch, section hidden when no posts
const allPosts = await getCollection("blog");
const latestPosts = allPosts
  .sort(
    (a, b) =>
      new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
  )
  .slice(0, 3);

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://primebiometry.com" },
  ],
};

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Top Identity Verification & KYC Software",
  description: "Independent comparison of leading identity verification, KYC, AML, and biometric authentication vendors",
  numberOfItems: topVendors.length,
  itemListElement: topVendors.map((v, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: v.name,
    url: `https://primebiometry.com/vendors/${v.slug}`,
  })),
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "What is the best identity verification software?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "The best identity verification software depends on your use case. For high-volume fintech onboarding, iDenfy and Veriff lead on price and accuracy. For enterprise compliance, Jumio and Onfido offer broader document and country coverage. PrimeBiometry independently scores 69 vendors across compliance, integration depth, pricing transparency, and accuracy.",
      },
    },
    {
      "@type": "Question",
      name: "How much does KYC software cost?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "KYC software pricing ranges from $0.55 per verification (iDenfy pay-as-you-go) to $1.50+ per check at enterprise tier. Most platforms offer free trials or sandbox access. Monthly SaaS plans typically start at $299–$999/month for small teams. Pricing scales with verification volume, document types, and compliance certifications required.",
      },
    },
    {
      "@type": "Question",
      name: "What is the difference between KYC and biometric verification?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "KYC (Know Your Customer) is a regulatory compliance process requiring identity checks before onboarding a user. Biometric verification is a technology method — liveness detection, face matching, fingerprint scanning — used to fulfill KYC requirements. Most modern KYC platforms include biometric verification, document verification, and deepfake detection as core steps.",
      },
    },
    {
      "@type": "Question",
      name: "Which identity verification platforms are GDPR compliant?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Most enterprise-grade platforms — iDenfy, Veriff, Onfido, Jumio, and ComplyCube — are GDPR compliant. Key signals to look for: SOC 2 Type II certification, ISO 27001, and EU data residency options. Our compliance coverage scores in each vendor profile reflect GDPR, CCPA, HIPAA, and iBeta PAD certification status.",
      },
    },
    {
      "@type": "Question",
      name: "How do I choose KYC compliance software?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Evaluate vendors on five criteria: (1) compliance certifications for your target markets (GDPR, CCPA, SOC 2), (2) document types and country coverage, (3) REST API and SDK integration depth, (4) per-verification pricing at your expected volume, and (5) liveness detection accuracy — iBeta PAD Level 2 is the industry benchmark for anti-spoofing. Read our full evaluation methodology for a detailed breakdown.",
      },
    },
  ],
};

// Homepage schema: Organization + WebSite with SiteLinksSearchBox
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      name: "PrimeBiometry",
      url: "https://primebiometry.com",
      description:
        "Independent comparison of biometric authentication and identity verification software",
      logo: {
        "@type": "ImageObject",
        url: "https://primebiometry.com/icon-192.png",
        width: 192,
        height: 192,
      },
    },
    {
      "@type": "WebSite",
      name: "PrimeBiometry",
      url: "https://primebiometry.com",
      potentialAction: {
        "@type": "SearchAction",
        target: {
          "@type": "EntryPoint",
          urlTemplate:
            "https://primebiometry.com/vendors?search={search_term_string}",
        },
        "query-input": "required name=search_term_string",
      },
    },
  ],
};
---

<BaseLayout
  title="Best Identity Verification & KYC Software 2026"
  description="Compare 69 identity verification, KYC, and AML software vendors. Independent scores on price, accuracy, and compliance. iDenfy $0.55/check, Veriff 99.6% accuracy."
  canonicalUrl="https://primebiometry.com"
  schema={[schema, breadcrumbSchema, itemListSchema, faqSchema]}
>

  <!-- 1. Hero ---------------------------------------------------------------->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 pt-16 pb-12 md:pt-24 md:pb-16">
    <h1 class="text-4xl md:text-5xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-100">
      Compare Identity Verification,<br class="hidden sm:block" /> KYC & AML Software
    </h1>
    <p class="mt-4 text-base text-zinc-600 dark:text-zinc-400 max-w-[65ch] leading-relaxed">
      Independent analysis, ratings, and pricing comparison of {vendors.length}+
      identity verification, KYC compliance, AML, document verification, and
      deepfake detection software vendors for enterprise security and compliance teams.
    </p>

    <!-- Search island with autocomplete -->
    <HeroSearch
      vendors={searchVendors}
      categories={searchCategories}
      client:idle
    />

    <!-- Category chip links — static anchors, no JS, param = slug -->
    <nav
      class="mt-4 flex flex-wrap gap-2"
      aria-label="Browse by category"
    >
      {categoryData.map((cat) => (
        <a
          href={`/categories/${cat.slug}`}
          class="inline-flex items-center rounded-full border border-zinc-200 dark:border-zinc-700 bg-white dark:bg-zinc-900 px-3 py-1 text-xs text-zinc-600 dark:text-zinc-400 hover:border-blue-300 dark:hover:border-blue-700 hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
        >
          {cat.name}
        </a>
      ))}
    </nav>
  </section>

  <!-- 2. Stats strip --------------------------------------------------------->
  <div class="bg-zinc-100 dark:bg-zinc-900 border-y border-zinc-200 dark:border-zinc-700">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-3 flex flex-wrap gap-x-6 gap-y-1">
      <span class="text-sm text-zinc-500 dark:text-zinc-400">
        <span class="font-mono font-semibold text-zinc-900 dark:text-zinc-100">
          {vendors.length}
        </span>{" "}vendors
      </span>
      <span class="text-sm text-zinc-500 dark:text-zinc-400">
        <span class="font-mono font-semibold text-zinc-900 dark:text-zinc-100">5</span>{" "}categories
      </span>
      <span class="text-sm text-zinc-500 dark:text-zinc-400">Updated June 2026</span>
    </div>
  </div>

  <!-- 3. Top Vendors --------------------------------------------------------->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 py-12 md:py-16">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-100">
        Top Identity Verification & KYC Vendors
      </h2>
      <a
        href="/vendors"
        class="text-sm text-blue-600 dark:text-blue-400 hover:underline"
      >
        Browse all {vendors.length}
      </a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {topVendors.map((v) => <VendorCard vendor={v} />)}
    </div>
  </section>

  <!-- 4. Browse by Category ------------------------------------------------->
  <section class="border-t border-zinc-200 dark:border-zinc-700 bg-zinc-50/50 dark:bg-zinc-950/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-12 md:py-16">
      <h2 class="text-2xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-100 mb-6">
        Browse by Category
      </h2>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-3">
        {categoryData.map((cat) => {
          const Icon = cat.Icon;
          return (
            <a
              href={`/categories/${cat.slug}`}
              class="group flex flex-col gap-3 rounded-lg border border-zinc-200 dark:border-zinc-700 bg-white dark:bg-zinc-900 p-4 hover:border-blue-300 dark:hover:border-blue-700 transition-colors"
            >
              <Icon
                size={20}
                weight="regular"
                className="text-zinc-400 dark:text-zinc-500 group-hover:text-blue-500 transition-colors"
              />
              <div>
                <p class="text-sm font-medium text-zinc-900 dark:text-zinc-100 leading-snug">
                  {cat.name}
                </p>
                <p class="mt-0.5 text-xs font-mono text-zinc-400 dark:text-zinc-500">
                  {cat.count} vendors
                </p>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- 5. Expert text + E-E-A-T ---------------------------------------------->
  <HomeExpertText />

  <!-- 6. Calculator CTA ------------------------------------------------------>
  <CalculatorCTA />

  <!-- 7. FAQ section ---------------------------------------------------------->
  <section class="border-t border-zinc-200 dark:border-zinc-700 bg-zinc-50/50 dark:bg-zinc-950/50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 py-12 md:py-16">
      <h2 class="text-2xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-100 mb-8">
        Frequently Asked Questions
      </h2>
      <dl class="space-y-6">
        <div>
          <dt class="text-base font-medium text-zinc-900 dark:text-zinc-100">
            What is the best identity verification software?
          </dt>
          <dd class="mt-2 text-base text-zinc-600 dark:text-zinc-400 leading-relaxed">
            The best identity verification software depends on your use case. For high-volume fintech
            onboarding, iDenfy and Veriff lead on price and accuracy. For enterprise compliance,
            Jumio and Onfido offer broader document and country coverage. PrimeBiometry independently
            scores {vendors.length} vendors across compliance, integration depth, pricing transparency, and accuracy.
          </dd>
        </div>
        <div>
          <dt class="text-base font-medium text-zinc-900 dark:text-zinc-100">
            How much does KYC software cost?
          </dt>
          <dd class="mt-2 text-base text-zinc-600 dark:text-zinc-400 leading-relaxed">
            KYC software pricing ranges from $0.55 per verification (iDenfy pay-as-you-go) to
            $1.50+ per check at enterprise tier. Of the {vendors.length} platforms we track, {publishedPricingCount} publish
            pricing transparently — the rest require a sales call for a quote. Monthly SaaS plans start
            at $299–$999/month for small teams and scale with verification volume, document types, and
            compliance certifications required.
          </dd>
        </div>
        <div>
          <dt class="text-base font-medium text-zinc-900 dark:text-zinc-100">
            What is the difference between KYC and biometric verification?
          </dt>
          <dd class="mt-2 text-base text-zinc-600 dark:text-zinc-400 leading-relaxed">
            KYC (Know Your Customer) is a regulatory compliance process requiring identity checks
            before onboarding. Biometric verification is a technology method — liveness detection,
            face matching, fingerprint scanning — used to fulfill KYC requirements. Most modern KYC
            platforms include biometric verification, document verification, and deepfake detection
            as core steps.
          </dd>
        </div>
        <div>
          <dt class="text-base font-medium text-zinc-900 dark:text-zinc-100">
            Which identity verification platforms are GDPR compliant?
          </dt>
          <dd class="mt-2 text-base text-zinc-600 dark:text-zinc-400 leading-relaxed">
            {gdprCount} of the {vendors.length} platforms we track carry GDPR compliance. Key signals to
            check: EU data residency options, a signed DPA, and whether biometric data is stored as
            mathematical templates rather than raw images. Our compliance scores in each vendor profile
            reflect GDPR, CCPA, SOC 2, HIPAA, and iBeta PAD certification status.
          </dd>
        </div>
        <div>
          <dt class="text-base font-medium text-zinc-900 dark:text-zinc-100">
            How do I choose KYC compliance software?
          </dt>
          <dd class="mt-2 text-base text-zinc-600 dark:text-zinc-400 leading-relaxed">
            Evaluate vendors on five criteria: compliance certifications for your target markets
            (GDPR, CCPA, SOC 2), document types and country coverage, REST API and SDK integration
            depth, per-verification pricing at your expected volume, and liveness detection accuracy
            — iBeta PAD Level 2 is the industry anti-spoofing benchmark.{" "}
            <a href="/methodology" class="text-blue-600 dark:text-blue-400 hover:underline">
              Read our full evaluation methodology →
            </a>
          </dd>
        </div>
      </dl>
    </div>
  </section>

  <!-- 8. Blog preview (hidden until posts exist) ---------------------------->
  {latestPosts.length > 0 && (
    <section class="border-t border-zinc-200 dark:border-zinc-700">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 py-12 md:py-16">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-2xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-100">
            Analysis & Guides
          </h2>
          <a href="/blog" class="text-sm text-blue-600 dark:text-blue-400 hover:underline">
            View all
          </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {latestPosts.map((post) => (
            <a
              href={`/blog/${post.slug}`}
              class="group flex flex-col gap-2 rounded-lg border border-zinc-200 dark:border-zinc-700 bg-white dark:bg-zinc-900 p-5 hover:border-blue-300 dark:hover:border-blue-700 transition-colors"
            >
              <p class="text-sm font-medium text-zinc-900 dark:text-zinc-100 leading-snug group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                {post.data.title}
              </p>
              <p class="text-xs font-mono text-zinc-400 dark:text-zinc-500">
                {new Date(post.data.pubDate).toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "short",
                  day: "numeric",
                })}
              </p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

</BaseLayout>
