---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import VendorCard from "../../../components/catalog/VendorCard.astro";
import BreadcrumbSchema from "../../../components/seo/BreadcrumbSchema.astro";
import {
  vendors,
  COMPLIANCE_LABELS,
  buildItemListSchema,
  type ComplianceFlags,
} from "../../../lib/vendors";
import siteConfig from "../../../../site.config";

// URL slug ↔ compliance_flags key
const STANDARD_MAP: Record<string, keyof ComplianceFlags> = {
  "iso-27001": "iso27001",
  "soc-2": "soc2_type2",
  "ibeta-pad-l2": "ibeta_pad_l2",
  "gdpr": "gdpr",
};

export async function getStaticPaths() {
  return [
    { params: { standard: "iso-27001" } },
    { params: { standard: "soc-2" } },
    { params: { standard: "ibeta-pad-l2" } },
    { params: { standard: "gdpr" } },
  ];
}

const { standard } = Astro.params;
const flagKey = STANDARD_MAP[standard as string];
const label = COMPLIANCE_LABELS[flagKey];

const matched = vendors
  .filter((v) => v.compliance_flags?.[flagKey])
  .sort((a, b) => {
    if (a.featured && !b.featured) return -1;
    if (!a.featured && b.featured) return 1;
    return b.rating - a.rating;
  });

const INTRO: Record<string, string> = {
  "iso-27001": `Identity verification and biometric vendors holding ISO/IEC 27001 certification — formal information security management aligned to international audit standards.`,
  "soc-2": `Biometric and KYC vendors with SOC 2 Type II attestation — independent audit of security, availability, and confidentiality controls over a sustained operating period.`,
  "ibeta-pad-l2": `Liveness detection and biometric vendors that passed iBeta ISO/IEC 30107-3 PAD Level 2 — the industry benchmark for resistance to presentation attacks including masks, replays, and 3D spoofs.`,
  "gdpr": `Identity verification platforms that publicly confirm GDPR compliance — data processing agreements, EU/EEA hosting options, and subject-rights workflows.`,
};

const SHORT_LABEL: Record<string, string> = {
  "iso-27001": "ISO 27001",
  "soc-2": "SOC 2 Type II",
  "ibeta-pad-l2": "iBeta PAD L2",
  "gdpr": "GDPR",
};

const intro = INTRO[standard as string];
const title = `${SHORT_LABEL[standard as string]} Certified Biometric Vendors 2026`;
const description = `Compare ${matched.length} identity verification vendors certified to ${label}. Compliance-verified KYC and biometric tools.`;
const canonicalUrl = `https://primebiometry.com/vendors/certified/${standard}`;

const itemListSchema = buildItemListSchema(
  matched,
  `${label} Certified Identity Verification and Biometric Vendors`,
  siteConfig.seo.siteUrl,
);

const breadcrumbItems = [
  { name: "Home", url: "/" },
  { name: "Vendors", url: "/vendors" },
  { name: label, url: `/vendors/certified/${standard}` },
];
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  schema={itemListSchema}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-10">
    <div class="mb-6">
      <BreadcrumbSchema items={breadcrumbItems} />
    </div>

    <div class="mb-8">
      <h1 class="text-4xl md:text-5xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-100">
        {label} Certified Biometric Vendors 2026
      </h1>
      <p class="mt-3 text-base text-zinc-600 dark:text-zinc-400 max-w-[65ch] leading-relaxed">
        {intro}
      </p>
      <p class="mt-2 text-sm text-zinc-500 dark:text-zinc-500">
        {matched.length} {matched.length === 1 ? "vendor" : "vendors"} matched ·
        <a class="text-blue-600 dark:text-blue-400 hover:underline" href={`/vendors?compliance=${flagKey}`}>
          Refine with more filters →
        </a>
      </p>
    </div>

    {matched.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 [&>a]:min-w-0">
        {matched.map((v) => <VendorCard vendor={v} />)}
      </div>
    ) : (
      <p class="text-sm text-zinc-500 dark:text-zinc-400">
        No vendors currently match this certification. <a class="text-blue-600 dark:text-blue-400 hover:underline" href="/vendors">Browse all vendors →</a>
      </p>
    )}
  </div>
</BaseLayout>
