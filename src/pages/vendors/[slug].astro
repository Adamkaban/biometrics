---
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import BreadcrumbSchema from "../../components/seo/BreadcrumbSchema.astro";
import ScoreBreakdown from "../../components/methodology/ScoreBreakdown.astro";
import MapPin from "phosphor-astro/MapPin.astro";
import CalendarBlank from "phosphor-astro/CalendarBlank.astro";
import Money from "phosphor-astro/Money.astro";
import Globe from "phosphor-astro/Globe.astro";
import Translate from "phosphor-astro/Translate.astro";
import Files from "phosphor-astro/Files.astro";
import {
  getVendorBySlug,
  getCategorySlug,
  getVendorsByCategory,
  pickComplianceFlags,
  COMPLIANCE_LABELS,
  PROFILE_COMPLIANCE_ORDER,
} from "../../lib/vendors";
import type { Vendor } from "../../lib/vendors";
import siteConfig from "../../../site.config";

export async function getStaticPaths() {
  const assessments = await getCollection("assessments");
  return assessments
    .map((entry) => {
      const vendor = getVendorBySlug(entry.slug);
      return {
        params: { slug: entry.slug },
        props: { entry, vendor },
      };
    })
    .filter((p) => p.props.vendor !== undefined);
}

interface Props {
  entry: CollectionEntry<"assessments">;
  vendor: Vendor;
}

const { entry, vendor } = Astro.props;
const { Content } = await entry.render();

// SEO
const pageTitle = entry.data.metaTitle ?? `${vendor.name} Review 2026`;

function trimToWordBoundary(text: string, maxLen: number): string {
  if (text.length <= maxLen) return text;
  const trimmed = text.slice(0, maxLen);
  const lastSpace = trimmed.lastIndexOf(" ");
  return lastSpace > 0 ? trimmed.slice(0, lastSpace) : trimmed;
}

function pricingSummary(v: Vendor): string {
  const raw = (v.pricing ?? "").toLowerCase();
  if (raw.includes("free trial")) return "offers a free trial";
  if (raw === "free") return "is free to use";
  if (raw.startsWith("starting at") || raw.startsWith("from")) {
    return `pricing ${v.pricing!.toLowerCase()}`;
  }
  if (raw.includes("contact")) return "uses contact-based enterprise pricing";
  return v.pricing ? `pricing: ${v.pricing}` : "pricing on request";
}

const metaDescription = entry.data.metaDescription
  ?? trimToWordBoundary(
      `${vendor.name} ${pricingSummary(vendor)}. ${entry.data.bestFor}. See alternatives and full breakdown.`,
      155
    );
const canonicalUrl = `${siteConfig.seo.siteUrl}/vendors/${vendor.slug}`;

// Schema
const schemaDescription = [
  entry.data.bestFor ? `Best for: ${entry.data.bestFor}.` : "",
  entry.data.avoidIf ? `Avoid if: ${entry.data.avoidIf}.` : "",
].filter(Boolean).join(" ") || vendor.description.slice(0, 200);

const softwareAppSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: vendor.name,
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  url: canonicalUrl,
  description: schemaDescription,
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: vendor.rating,
    reviewCount: vendor.reviews_count,
    bestRating: 5,
    worstRating: 1,
  },
};

// Breadcrumb items
const primaryCategory = vendor.categories[0];
const categorySlug = getCategorySlug(primaryCategory);
const breadcrumbItems = [
  { name: "Home", url: "/" },
  { name: "Vendors", url: "/vendors" },
  ...(primaryCategory
    ? [{ name: primaryCategory, url: `/categories/${categorySlug}` }]
    : []),
  { name: vendor.name, url: `/vendors/${vendor.slug}` },
];

const pricingPlans = vendor.website_data?.pricing_plans ?? [];

const SDK_LABELS: Record<string, string> = {
  web_sdk: "Web SDK",
  ios_sdk: "iOS SDK",
  android_sdk: "Android SDK",
  flutter: "Flutter",
  react_native: "React Native",
  rest_api: "REST API",
  no_code: "No-Code",
};

const activeComplianceFlags = pickComplianceFlags(vendor, PROFILE_COMPLIANCE_ORDER);
const integrationLabels = vendor.integration_methods?.length
  ? vendor.integration_methods
  : (vendor.sdk_types ?? []).map((s) => SDK_LABELS[s] ?? s.replace(/_/g, " "));

// Blog posts relevant to vendor categories
const VENDOR_CAT_BLOG_SLUGS: Record<string, string[]> = {
  "KYC Compliance": [
    "best-kyc-aml-software-2026",
    "kyc-pricing-guide-2026",
    "veriff-vs-jumio-2026",
  ],
  "AML": [
    "kyc-aml-compliance-checklist-fintech-2026",
    "best-kyc-aml-software-2026",
  ],
  "Identity Verification": [
    "veriff-vs-jumio-2026",
    "best-kyc-aml-software-2026",
  ],
};

const allBlogPosts = await getCollection("blog");
const relevantSlugs = vendor.categories.flatMap(
  (cat) => VENDOR_CAT_BLOG_SLUGS[cat] ?? []
);
const uniqueSlugs = [...new Set(relevantSlugs)];
const relatedPosts = allBlogPosts
  .filter((p) => uniqueSlugs.includes(p.slug))
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 3);

// Alternatives: top 3 other vendors from same primary category
const alternatives = primaryCategory
  ? getVendorsByCategory(primaryCategory)
      .filter((v) => v.slug !== vendor.slug)
      .sort((a, b) => b.rating - a.rating)
      .slice(0, 3)
  : [];

// Auto-generate FAQPage from existing assessment + vendor data — no MDX changes needed
const autoFaqItems = [
  {
    q: `How much does ${vendor.name} cost?`,
    a: `${vendor.name} pricing: ${vendor.pricing}.${pricingPlans.length > 0 ? ` Plans available: ${pricingPlans.map((p) => `${p.name} at ${p.price}`).join(", ")}.` : ""}`,
  },
  {
    q: `Who is ${vendor.name} best for?`,
    a: entry.data.bestFor,
  },
  {
    q: `How difficult is ${vendor.name} to integrate?`,
    a: `${vendor.name} has ${entry.data.integrationComplexity.toLowerCase()} integration complexity.`,
  },
  ...(entry.data.avoidIf
    ? [{ q: `What are the limitations of ${vendor.name}?`, a: entry.data.avoidIf }]
    : []),
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: autoFaqItems.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: { "@type": "Answer", text: item.a },
  })),
};
---

<BaseLayout
  title={pageTitle}
  description={metaDescription}
  canonicalUrl={canonicalUrl}
  schema={[softwareAppSchema, faqSchema]}
  includeTally={vendor.featured && !!siteConfig.monetization.tallyFormId}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-10">
    <!-- Breadcrumb -->
    <BreadcrumbSchema items={breadcrumbItems} />

    <div class="flex flex-col lg:flex-row gap-10 mt-6">
      <!-- Left 70% -->
      <div class="flex-1 min-w-0">
        <h1
          class="text-4xl md:text-5xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-100 mb-2"
        >
          {vendor.name} Review 2026: Pricing, Features & Alternatives
        </h1>

        <!-- Last updated -->
        <p class="text-sm text-zinc-500 dark:text-zinc-400 mb-6">
          Last updated:
          <time datetime={entry.data.lastUpdated.toISOString().slice(0, 10)}>
            {entry.data.lastUpdated.toISOString().slice(0, 10)}
          </time>
          &middot; by {entry.data.author}
        </p>

        <!-- PrimeBiometry Score (v2.0 methodology) — only when scoreBreakdown is present in frontmatter -->
        {entry.data.scoreBreakdown && (
          <ScoreBreakdown
            compliance={entry.data.scoreBreakdown.compliance}
            integration={entry.data.scoreBreakdown.integration}
            marketCoverage={entry.data.scoreBreakdown.marketCoverage}
            pricingTransparency={entry.data.scoreBreakdown.pricingTransparency}
            userSentiment={entry.data.scoreBreakdown.userSentiment}
            total={entry.data.scoreBreakdown.total}
            scoredAt={entry.data.scoreBreakdown.scoredAt}
            methodologyVersion={entry.data.scoreBreakdown.methodologyVersion}
          />
        )}

        <!-- Assessment MDX content -->
        <div class="prose prose-zinc dark:prose-invert max-w-none">
          <Content />
        </div>

        <!-- Pricing plans table -->
        {
          pricingPlans.length > 0 && (
            <section class="mt-10">
              <h2 class="text-2xl font-semibold text-zinc-900 dark:text-zinc-100">
                Pricing Plans
              </h2>
              <div class="mt-4 grid gap-4 sm:grid-cols-2">
                {pricingPlans.map((plan) => (
                  <div class="border border-zinc-200 dark:border-zinc-700 rounded-lg p-5">
                    <h3 class="font-semibold text-zinc-900 dark:text-zinc-100">
                      {plan.name}
                    </h3>
                    <p class="text-xl font-mono text-blue-600 mt-1">
                      {plan.price}
                    </p>
                    <ul class="mt-3 space-y-1">
                      {(plan.features_included ?? []).slice(0, 5).map((f) => (
                        <li class="text-sm text-zinc-600 dark:text-zinc-400 flex gap-2">
                          <span class="text-emerald-600 shrink-0">&#10003;</span>
                          {f}
                        </li>
                      ))}
                    </ul>
                  </div>
                ))}
              </div>
            </section>
          )
        }
        <!-- Verification capabilities -->
        {vendor.verification_types && vendor.verification_types.length > 0 && (
          <section class="mt-8">
            <h2 class="text-xl font-semibold text-zinc-900 dark:text-zinc-100">Verification Capabilities</h2>
            <div class="mt-3 flex flex-wrap gap-2">
              {vendor.verification_types.map(vt => (
                <span class="rounded-md bg-amber-50 px-3 py-1 text-sm text-amber-800 dark:bg-amber-950/30 dark:text-amber-400">
                  {vt}
                </span>
              ))}
            </div>
          </section>
        )}

        <!-- Compliance & Certifications -->
        {(activeComplianceFlags.length > 0 || (vendor.compliance_certifications_other?.length ?? 0) > 0) && (
          <section class="mt-8">
            <h2 class="text-xl font-semibold text-zinc-900 dark:text-zinc-100">Compliance & Certifications</h2>
            {activeComplianceFlags.length > 0 && (
              <div class="mt-3 flex flex-wrap gap-2">
                {activeComplianceFlags.map(k => (
                  <span class="rounded-md border border-zinc-200 px-3 py-1 text-sm dark:border-zinc-700">
                    {COMPLIANCE_LABELS[k]}
                  </span>
                ))}
              </div>
            )}
            {vendor.compliance_certifications_other?.length > 0 && (
              <>
                <p class="mt-4 text-xs uppercase tracking-wide text-zinc-500">Additional certifications</p>
                <div class="mt-2 flex flex-wrap gap-2">
                  {vendor.compliance_certifications_other.map(c => (
                    <span class="rounded-md border border-dashed border-zinc-200 px-3 py-1 text-xs text-zinc-500 dark:border-zinc-700">
                      {c}
                    </span>
                  ))}
                </div>
              </>
            )}
          </section>
        )}

        <!-- SDK & Integration -->
        {integrationLabels.length > 0 && (
          <section class="mt-8">
            <h2 class="text-xl font-semibold text-zinc-900 dark:text-zinc-100">Integration</h2>
            <div class="mt-3 flex flex-wrap gap-2">
              {integrationLabels.map(label => (
                <span class="rounded-md bg-blue-50 px-3 py-1 text-sm text-blue-700 dark:bg-blue-950/30 dark:text-blue-400">
                  {label}
                </span>
              ))}
            </div>
          </section>
        )}

        <!-- Related blog posts -->
        {relatedPosts.length > 0 && (
          <section class="mt-10">
            <h2 class="text-xl font-semibold text-zinc-900 dark:text-zinc-100 mb-4">
              Related Guides
            </h2>
            <div class="flex flex-col gap-3">
              {relatedPosts.map((post) => (
                <a
                  href={`/blog/${post.slug}`}
                  class="group flex flex-col gap-1 rounded-lg border border-zinc-200 dark:border-zinc-700 bg-white dark:bg-zinc-900 p-4 hover:border-blue-300 dark:hover:border-blue-700 transition-colors"
                >
                  <p class="text-sm font-medium text-zinc-900 dark:text-zinc-100 leading-snug group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                    {post.data.title}
                  </p>
                  <p class="text-xs text-zinc-500 dark:text-zinc-400">{post.data.description.slice(0, 100)}…</p>
                </a>
              ))}
            </div>
          </section>
        )}

        <!-- Compare alternatives -->
        {alternatives.length > 0 && (
          <section class="mt-10">
            <h2 class="text-xl font-semibold text-zinc-900 dark:text-zinc-100 mb-4">
              Compare Alternatives
            </h2>
            <div class="flex flex-col gap-3">
              {alternatives.map((alt) => (
                <a
                  href={`/vendors/${alt.slug}`}
                  class="group flex items-center justify-between gap-4 rounded-lg border border-zinc-200 dark:border-zinc-700 bg-white dark:bg-zinc-900 p-4 hover:border-blue-300 dark:hover:border-blue-700 transition-colors"
                >
                  <div class="min-w-0">
                    <p class="text-sm font-medium text-zinc-900 dark:text-zinc-100 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                      {alt.name}
                    </p>
                    <p class="text-xs font-mono text-zinc-500 dark:text-zinc-400">{alt.pricing}</p>
                  </div>
                  <span class="shrink-0 text-sm font-mono font-semibold text-zinc-700 dark:text-zinc-300">
                    {alt.rating.toFixed(1)}
                  </span>
                </a>
              ))}
            </div>
            <a
              href={`/categories/${categorySlug}`}
              class="mt-4 inline-block text-sm text-blue-600 dark:text-blue-400 hover:underline"
            >
              See all {primaryCategory} vendors →
            </a>
          </section>
        )}
      </div>

      <!-- Right 30% sticky sidebar -->
      <aside class="lg:w-80 shrink-0">
        <div class="sticky top-[72px]">
          <div
            class="rounded-lg border border-zinc-200 dark:border-zinc-700 bg-white dark:bg-zinc-900 p-6 space-y-5"
          >
            <!-- Logo + name -->
            <div class="flex items-center gap-3">
              {
                <img
                  src={vendor.logo_url || "/favicon.svg"}
                  width="40"
                  height="40"
                  class="rounded object-contain"
                  alt={`${vendor.name} logo`}
                  title={`${vendor.name} logo`}
                  loading="eager"
                  decoding="async"
                />
              }
              <span class="font-semibold text-zinc-900 dark:text-zinc-100"
                >{vendor.name}</span
              >
            </div>

            <!-- Rating -->
            <div>
              <span
                class="text-3xl font-mono font-semibold text-zinc-900 dark:text-zinc-100"
              >
                {vendor.rating.toFixed(1)}
              </span>
              <span class="text-sm text-zinc-500 ml-2"
                >{vendor.reviews_count} reviews</span
              >
            </div>

            <!-- Rating histogram -->
            {vendor.rating_breakdown && (
              <div class="mt-3 space-y-1">
                {([5, 4, 3, 2, 1] as const).map(star => {
                  const count = vendor.rating_breakdown![star] ?? 0;
                  const total = vendor.total_reviews_all_sources ?? vendor.reviews_count;
                  const pct = total > 0 ? Math.round((count / total) * 100) : 0;
                  return (
                    <div class="flex items-center gap-2 text-xs">
                      <span class="w-4 text-right text-zinc-500">{star}★</span>
                      <div class="h-1.5 flex-1 rounded-full bg-zinc-100 dark:bg-zinc-800">
                        <div class="h-1.5 rounded-full bg-amber-400" style={`width: ${pct}%`} />
                      </div>
                      <span class="w-7 text-right font-mono text-zinc-500">{pct}%</span>
                    </div>
                  );
                })}
              </div>
            )}

            <!-- Company info -->
            {(vendor.website_data?.headquarters || vendor.website_data?.founded_year || vendor.company_data?.total_funding || vendor.countries_count != null || vendor.global_claim) && (
              <div class="mt-6 space-y-2 text-sm text-zinc-600 dark:text-zinc-400">
                {vendor.website_data?.headquarters && (
                  <p class="flex items-center gap-1.5">
                    <MapPin width={14} height={14} class="shrink-0" aria-hidden="true" />
                    {vendor.website_data.headquarters}
                  </p>
                )}
                {vendor.website_data?.founded_year && (
                  <p class="flex items-center gap-1.5">
                    <CalendarBlank width={14} height={14} class="shrink-0" aria-hidden="true" />
                    Founded {vendor.website_data.founded_year}
                  </p>
                )}
                {vendor.company_data?.funding_display && vendor.company_data?.total_funding && (
                  <p class="flex items-center gap-1.5">
                    <Money width={14} height={14} class="shrink-0" aria-hidden="true" />
                    {vendor.company_data.total_funding} {vendor.company_data.funding_stage}
                  </p>
                )}
                {vendor.countries_count != null ? (
                  <p class="flex items-center gap-1.5">
                    <Globe width={14} height={14} class="shrink-0" aria-hidden="true" />
                    {vendor.countries_count}+ countries
                  </p>
                ) : vendor.global_claim ? (
                  <p class="flex items-center gap-1.5">
                    <Globe width={14} height={14} class="shrink-0" aria-hidden="true" />
                    Global coverage
                  </p>
                ) : null}
                {vendor.languages_count != null && (
                  <p class="flex items-center gap-1.5">
                    <Translate width={14} height={14} class="shrink-0" aria-hidden="true" />
                    {vendor.languages_count}+ languages
                  </p>
                )}
                {vendor.documents_count != null && (
                  <p class="flex items-center gap-1.5">
                    <Files width={14} height={14} class="shrink-0" aria-hidden="true" />
                    {vendor.documents_count}+ document types
                  </p>
                )}
              </div>
            )}

            <!-- Pricing summary -->
            <div>
              <p class="text-xs uppercase tracking-wide text-zinc-500 mb-1">
                Pricing
              </p>
              <p class="text-lg font-mono font-semibold text-zinc-900 dark:text-zinc-100">
                {vendor.pricing_summary || vendor.pricing}
              </p>
              {vendor.starting_price?.raw && vendor.starting_price.raw !== vendor.pricing_summary && (
                <p class="mt-1 text-xs text-zinc-500 dark:text-zinc-400">
                  Source: <span class="font-mono">{vendor.starting_price.raw}</span>
                </p>
              )}
              {vendor.min_monthly_commitment && (
                <p class="mt-1 text-xs text-zinc-500 dark:text-zinc-400">
                  Min commitment: <span class="font-mono">${vendor.min_monthly_commitment.amount}/mo</span>
                </p>
              )}
              {vendor.free_trial && (
                <p class="mt-1 text-xs text-emerald-700 dark:text-emerald-400">
                  Free trial{vendor.free_trial.days ? ` (${vendor.free_trial.days} days)` : ""}
                </p>
              )}
              {vendor.free_tier && (
                <p class="mt-1 text-xs text-emerald-700 dark:text-emerald-400">
                  Free tier{vendor.free_tier.amount ? ` (${vendor.free_tier.amount} ${vendor.free_tier.unit ?? ""})` : ""}
                </p>
              )}
            </div>

            <!-- Integration complexity -->
            <div>
              <p class="text-xs uppercase tracking-wide text-zinc-500 mb-1">
                Integration
              </p>
              <span
                class:list={[
                  "inline-block text-sm font-medium px-2 py-0.5 rounded-full",
                  entry.data.integrationComplexity === "Low" &&
                    "bg-emerald-100 dark:bg-emerald-950/40 text-emerald-700 dark:text-emerald-400",
                  entry.data.integrationComplexity === "Medium" &&
                    "bg-amber-100 dark:bg-amber-950/40 text-amber-700 dark:text-amber-400",
                  entry.data.integrationComplexity === "High" &&
                    "bg-red-100 dark:bg-red-950/40 text-red-700 dark:text-red-400",
                ]}
              >
                {entry.data.integrationComplexity}
              </span>
            </div>

            <!-- Get Quote (featured only) -->
            {
              vendor.featured && siteConfig.monetization.tallyFormId && (
                <button
                  data-tally-open={siteConfig.monetization.tallyFormId}
                  data-tally-overlay="1"
                  data-tally-hide-title="1"
                  data-tally-vendor={vendor.name}
                  class="w-full bg-blue-600 text-white rounded-md px-4 py-2.5 text-sm font-medium hover:bg-blue-700 transition-colors"
                >
                  Get Quote
                </button>
              )
            }

            <!-- Visit Website button (always shown) -->
            <a
              href={`/go/${vendor.slug}`}
              rel="nofollow noopener"
              target="_blank"
              class="block w-full text-center border border-zinc-200 dark:border-zinc-700 text-zinc-700 dark:text-zinc-300 rounded-md px-4 py-2.5 text-sm font-medium hover:bg-zinc-50 dark:hover:bg-zinc-800 transition-colors"
            >
              Visit Website
            </a>

            <!-- Categories -->
            {
              vendor.categories.length > 0 && (
                <div>
                  <p class="text-xs uppercase tracking-wide text-zinc-500 mb-2">
                    Categories
                  </p>
                  <div class="flex flex-wrap gap-2">
                    {vendor.categories.map((cat) => (
                      <a
                        href={`/categories/${getCategorySlug(cat)}`}
                        class="text-xs bg-zinc-100 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400 rounded-full px-2 py-0.5 hover:bg-zinc-200 dark:hover:bg-zinc-700 transition-colors"
                      >
                        {cat}
                      </a>
                    ))}
                  </div>
                </div>
              )
            }

            <!-- Data Sources -->
            <div>
              <p class="text-xs uppercase tracking-wide text-zinc-500 mb-2">
                Data Sources
              </p>
              <div class="flex flex-wrap gap-2">
                {
                  vendor.all_sources.map((src) => (
                    <span class="text-xs bg-zinc-100 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400 rounded-full px-2 py-0.5 capitalize">
                      {src}
                    </span>
                  ))
                }
              </div>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
