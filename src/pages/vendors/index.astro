---
import BaseLayout from "../../layouts/BaseLayout.astro";
import VendorCard from "../../components/catalog/VendorCard.astro";
import VendorFilters from "../../components/catalog/VendorFilters";
import BreadcrumbSchema from "../../components/seo/BreadcrumbSchema.astro";
import {
  vendors,
  categories,
  SDK_FILTER_LABELS,
  FILTERABLE_COMPLIANCE,
  INDUSTRY_BUCKETS,
  buildItemListSchema,
  getVendorIndustries,
  type IndustryBucketKey,
} from "../../lib/vendors";
import siteConfig from "../../../site.config";
import { getCollection } from "astro:content";

// Server-side sort: featured first (by rating desc), then non-featured (by rating desc)
const sortedVendors = [...vendors].sort((a, b) => {
  if (a.featured && !b.featured) return -1;
  if (!a.featured && b.featured) return 1;
  return b.rating - a.rating;
});

// Facet counts — total vendor matches per option (not intersection with active filters)
const counts = {
  sdk: Object.fromEntries(
    Object.keys(SDK_FILTER_LABELS).map((k) => [
      k,
      vendors.filter((v) => v.sdk_types?.includes(k)).length,
    ])
  ),
  compliance: Object.fromEntries(
    FILTERABLE_COMPLIANCE.map((k) => [
      k,
      vendors.filter((v) => v.compliance_flags?.[k]).length,
    ])
  ),
  industry: Object.fromEntries(
    (Object.keys(INDUSTRY_BUCKETS) as IndustryBucketKey[]).map((k) => [
      k,
      vendors.filter((v) => getVendorIndustries(v).includes(k)).length,
    ])
  ),
};

// ItemList schema — each ListItem wraps a SoftwareApplication with AggregateRating
const itemListSchema = buildItemListSchema(
  sortedVendors,
  "Biometric Authentication and Identity Verification Software",
  siteConfig.seo.siteUrl,
);

const breadcrumbItems = [
  { name: "Home", url: "/" },
  { name: "Vendors", url: "/vendors" },
];

const allPosts = await getCollection("blog");
const latestPosts = allPosts
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 3);
---

<BaseLayout
  title="Biometric Vendor Directory: 69 Tools 2026"
  description="69 identity verification and biometric vendors ranked by price, accuracy, and SDK coverage. Filter by compliance (SOC2, GDPR, ISO 27001). Updated weekly."
  canonicalUrl="https://primebiometry.com/vendors"
  schema={itemListSchema}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-10">
    <div class="mb-6">
      <BreadcrumbSchema items={breadcrumbItems} />
    </div>

    <div class="mb-8">
      <h1 class="text-4xl md:text-5xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-100">
        Compare Biometric Software
      </h1>
      <p class="mt-3 text-base text-zinc-600 dark:text-zinc-400 max-w-[65ch]">
        {vendors.length} vendors across identity verification, KYC compliance, and biometric authentication.
      </p>
    </div>

    <div class="flex flex-col lg:flex-row gap-8 items-start">
      <aside class="w-full lg:w-64 shrink-0">
        <div class="sticky top-[72px]">
          <h2 class="text-sm font-semibold text-zinc-900 dark:text-zinc-100 mb-4">Filters</h2>
          <VendorFilters
            categories={categories}
            initialParams={Astro.url.search}
            counts={counts}
            client:load
          />
        </div>
      </aside>

      <main class="flex-1 min-w-0">
        <div data-dedicated-page-slot></div>
        <div data-vendor-grid class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 [&>a]:min-w-0">
          {sortedVendors.map(v => <VendorCard vendor={v} />)}
        </div>
      </main>
    </div>
  </div>

  {latestPosts.length > 0 && (
    <div class="border-t border-zinc-200 dark:border-zinc-700 mt-12">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 py-12">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-xl font-semibold text-zinc-900 dark:text-zinc-100">Analysis & Guides</h2>
          <a href="/blog" class="text-sm text-blue-600 dark:text-blue-400 hover:underline">View all</a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          {latestPosts.map((post) => (
            <a
              href={`/blog/${post.slug}`}
              class="group flex flex-col gap-2 rounded-lg border border-zinc-200 dark:border-zinc-700 bg-white dark:bg-zinc-900 p-5 hover:border-blue-300 dark:hover:border-blue-700 transition-colors"
            >
              <p class="text-sm font-medium text-zinc-900 dark:text-zinc-100 leading-snug group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                {post.data.title}
              </p>
              <p class="text-xs font-mono text-zinc-400 dark:text-zinc-500">
                {new Date(post.data.pubDate).toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "short",
                  day: "numeric",
                })}
              </p>
            </a>
          ))}
        </div>
      </div>
    </div>
  )}
</BaseLayout>
