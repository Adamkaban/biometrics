---
import BaseLayout from "../../layouts/BaseLayout.astro";
import VendorCard from "../../components/catalog/VendorCard.astro";
import VendorFilters from "../../components/catalog/VendorFilters";
import BreadcrumbSchema from "../../components/seo/BreadcrumbSchema.astro";
import {
  vendors,
  categories,
  SDK_FILTER_LABELS,
  FILTERABLE_COMPLIANCE,
  INDUSTRY_BUCKETS,
  COMPLIANCE_LABELS,
  buildItemListSchema,
  getVendorIndustries,
  getVendorBillingBucket,
  VALUE_TIER_FILTER_ORDER,
  BILLING_FILTER_ORDER,
  type IndustryBucketKey,
} from "../../lib/vendors";
import siteConfig from "../../../site.config";
import { getCollection } from "astro:content";

// Server-side sort: featured first (by rating desc), then non-featured (by rating desc)
const sortedVendors = [...vendors].sort((a, b) => {
  if (a.featured && !b.featured) return -1;
  if (!a.featured && b.featured) return 1;
  return b.rating - a.rating;
});

// Facet counts — total vendor matches per option (not intersection with active filters)
const counts = {
  sdk: Object.fromEntries(
    Object.keys(SDK_FILTER_LABELS).map((k) => [
      k,
      vendors.filter((v) => v.sdk_types?.includes(k)).length,
    ])
  ),
  compliance: Object.fromEntries(
    FILTERABLE_COMPLIANCE.map((k) => [
      k,
      vendors.filter((v) => v.compliance_flags?.[k]).length,
    ])
  ),
  industry: Object.fromEntries(
    (Object.keys(INDUSTRY_BUCKETS) as IndustryBucketKey[]).map((k) => [
      k,
      vendors.filter((v) => getVendorIndustries(v).includes(k)).length,
    ])
  ),
  tier: Object.fromEntries(
    VALUE_TIER_FILTER_ORDER.map((k) => [
      k,
      vendors.filter((v) => v.value_tier === k).length,
    ])
  ),
  billing: Object.fromEntries(
    BILLING_FILTER_ORDER.map((k) => [
      k,
      vendors.filter((v) => getVendorBillingBucket(v) === k).length,
    ])
  ),
};

// ItemList schema — each ListItem wraps a SoftwareApplication with AggregateRating
const itemListSchema = buildItemListSchema(
  sortedVendors,
  "Biometric Authentication and Identity Verification Software",
  siteConfig.seo.siteUrl,
);

const breadcrumbItems = [
  { name: "Home", url: "/" },
  { name: "Vendors", url: "/vendors" },
];

const collectionPageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Compare Biometric Software 2026: 69 Vendors",
  description:
    "69 biometric software vendors compared: liveness detection, identity verification, KYC compliance. Filter by SDK, pricing, and certification. Updated 2026.",
  url: `${siteConfig.seo.siteUrl}/vendors`,
  numberOfItems: sortedVendors.length,
};

const schemas = [itemListSchema, collectionPageSchema];

const SDK_PAGE_SLUGS: Record<string, string> = {
  web_sdk: "web-sdk",
  ios_sdk: "ios-sdk",
  android_sdk: "android-sdk",
  rest_api: "rest-api",
  no_code: "no-code",
};
const COMPLIANCE_PAGE_SLUGS: Record<string, string> = {
  iso27001: "iso-27001",
  soc2_type2: "soc-2",
  ibeta_pad_l2: "ibeta-pad-l2",
  gdpr: "gdpr",
};

const allPosts = await getCollection("blog");
const latestPosts = allPosts
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 3);
---

<BaseLayout
  title="Compare Biometric Software 2026: 69 Vendors"
  description="69 biometric software vendors compared: liveness detection, identity verification, KYC compliance. Filter by SDK, pricing, and certification. Updated 2026."
  canonicalUrl="https://primebiometry.com/vendors"
  schema={schemas}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-10">
    <div class="mb-6">
      <BreadcrumbSchema items={breadcrumbItems} />
    </div>

    <div class="mb-8">
      <h1 class="text-4xl md:text-5xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-100">
        Best Biometric Software 2026: {vendors.length} Vendors Compared
      </h1>

      <div class="mt-3 flex flex-wrap gap-x-5 gap-y-1 text-xs font-mono text-zinc-400 dark:text-zinc-500">
        <span>{vendors.length} vendors</span>
        <span>5 categories</span>
        <span>Pricing from $0.10/verification</span>
        <span>Updated June 2026</span>
      </div>

      <div class="mt-5 space-y-3">
        <p class="text-base text-zinc-600 dark:text-zinc-400 leading-relaxed">
          Picking biometric software is harder than it looks. Liveness detection accuracy, document verification coverage, API response times, compliance certifications, and pricing models vary wildly across vendors who all claim to be the right fit for your use case.
        </p>
        <p class="text-base text-zinc-600 dark:text-zinc-400 leading-relaxed">
          This directory covers {vendors.length} identity verification and biometric authentication providers. Each entry shows published pricing, SDK support (web, iOS, Android, REST API), compliance status (SOC 2 Type II, ISO 27001, GDPR, iBeta PAD Level 2), and aggregated ratings from G2, Gartner, and Capterra.
        </p>
        <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed">
          Use the filters to find a KYC onboarding solution, a passive liveness detection provider, a face recognition API, or an AML screening platform. Rankings reflect aggregated ratings. Featured vendors are editorially selected.{" "}
          <a href="/methodology" class="text-blue-600 dark:text-blue-400 hover:underline">See how we evaluate vendors.</a>
        </p>
      </div>
    </div>

    <div class="flex flex-col lg:flex-row gap-8 items-start">
      <aside class="w-full lg:w-64 shrink-0">
        <div class="sticky top-[72px]">
          <h2 class="text-sm font-semibold text-zinc-900 dark:text-zinc-100 mb-4">Filter biometric vendors</h2>
          <VendorFilters
            categories={categories}
            initialParams={Astro.url.search}
            counts={counts}
            client:load
          />
        </div>
      </aside>

      <main class="flex-1 min-w-0">
        <div data-dedicated-page-slot></div>
        <div data-vendor-grid class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 [&>a]:min-w-0">
          {sortedVendors.map(v => <VendorCard vendor={v} />)}
        </div>
      </main>
    </div>
  </div>

  {latestPosts.length > 0 && (
    <div class="border-t border-zinc-200 dark:border-zinc-700 mt-12">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 py-12">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-xl font-semibold text-zinc-900 dark:text-zinc-100">Analysis & Guides</h2>
          <a href="/blog" class="text-sm text-blue-600 dark:text-blue-400 hover:underline">View all</a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          {latestPosts.map((post) => (
            <a
              href={`/blog/${post.slug}`}
              class="group flex flex-col gap-2 rounded-lg border border-zinc-200 dark:border-zinc-700 bg-white dark:bg-zinc-900 p-5 hover:border-blue-300 dark:hover:border-blue-700 transition-colors"
            >
              <p class="text-sm font-medium text-zinc-900 dark:text-zinc-100 leading-snug group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                {post.data.title}
              </p>
              <p class="text-xs font-mono text-zinc-400 dark:text-zinc-500">
                {new Date(post.data.pubDate).toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "short",
                  day: "numeric",
                })}
              </p>
            </a>
          ))}
        </div>
      </div>
    </div>
  )}

  <div class="border-t border-zinc-200 dark:border-zinc-700">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-12">
      <h2 class="text-xl font-semibold text-zinc-900 dark:text-zinc-100 mb-6">Browse Vendors By</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div>
          <h3 class="text-xs font-semibold text-zinc-500 uppercase tracking-wide mb-3">Industry</h3>
          <ul class="space-y-2">
            {(Object.keys(INDUSTRY_BUCKETS) as IndustryBucketKey[]).map((key) => (
              <li>
                <a href={`/vendors/for/${key}`} class="text-sm text-blue-600 dark:text-blue-400 hover:underline">
                  {INDUSTRY_BUCKETS[key].label}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div>
          <h3 class="text-xs font-semibold text-zinc-500 uppercase tracking-wide mb-3">Integration</h3>
          <ul class="space-y-2">
            {Object.entries(SDK_FILTER_LABELS).map(([key, label]) => (
              <li>
                <a href={`/vendors/with/${SDK_PAGE_SLUGS[key]}`} class="text-sm text-blue-600 dark:text-blue-400 hover:underline">
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div>
          <h3 class="text-xs font-semibold text-zinc-500 uppercase tracking-wide mb-3">Certification</h3>
          <ul class="space-y-2">
            {FILTERABLE_COMPLIANCE.map((key) => (
              <li>
                <a href={`/vendors/certified/${COMPLIANCE_PAGE_SLUGS[key]}`} class="text-sm text-blue-600 dark:text-blue-400 hover:underline">
                  {COMPLIANCE_LABELS[key]}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
