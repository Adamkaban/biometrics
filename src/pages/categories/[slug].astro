---
import BaseLayout from "../../layouts/BaseLayout.astro";
import VendorCard from "../../components/catalog/VendorCard.astro";
import BreadcrumbSchema from "../../components/seo/BreadcrumbSchema.astro";
import CategoryQuickFilters from "../../components/catalog/CategoryQuickFilters.astro";
import {
  CATEGORY_SLUGS,
  buildItemListSchema,
  getVendorsByCategory,
} from "../../lib/vendors";
import { CATEGORY_CONTENT } from "../../lib/category-content";
import { getCollection } from "astro:content";
import siteConfig from "../../../site.config";

export function getStaticPaths() {
  return Object.entries(CATEGORY_SLUGS).map(([name, slug]) => ({
    params: { slug },
    props: { categoryName: name },
  }));
}

interface Props {
  categoryName: string;
}

// SERP-only meta (decoupled from on-page CATEGORY_DESCRIPTIONS body copy)
const CATEGORY_META: Record<string, { title: string; description: string }> = {
  "Biometric Authentication": {
    title: "Biometric Auth Software 2026: 38 Tools",
    description: "38 biometric auth platforms scored on liveness accuracy, ISO 30107 PAD certification, SDK coverage, and price. Open source to enterprise. Pick the right fit.",
  },
  "KYC Compliance": {
    title: "Best KYC Compliance Software 2026: 24 Vendors",
    description: "24 KYC platforms tested on per-check cost ($0.05 to $3), AML coverage, country support, monthly minimums. iDenfy wins low volume, Sumsub for crypto stacks.",
  },
  "Identity Verification": {
    title: "Identity Verification 2026: 60 Vendors",
    description: "60 IDV vendors ranked on document coverage (250+ ID types), liveness pass rate, API latency, and per-verification price. Real numbers, updated June 2026.",
  },
  "AML": {
    title: "Best AML Compliance Software 2026: 10 Tools",
    description: "Compare 10 anti-money laundering software tools: OFAC/EU/UN sanctions screening, transaction monitoring, PEP coverage, Travel Rule. Ranked for banks and fintechs.",
  },
  "Fraud Prevention": {
    title: "Fraud Prevention 2026: Device + Behavior",
    description: "6 fraud platforms compared on device fingerprinting depth, behavioral signals, false-positive rate, and integration time. Vendor decks stripped, numbers shown.",
  },
};

const CATEGORY_DESCRIPTIONS: Record<string, string> = {
  "Biometric Authentication":
    "Biometric authentication software uses physical characteristics -- face, fingerprint, voice, or iris -- to verify identity. These solutions replace passwords with hardware sensors or software-based cameras, reducing credential theft risk while improving user experience.",
  "KYC Compliance":
    "Know Your Customer (KYC) compliance software automates identity verification during customer onboarding. Regulated industries use these tools to verify government-issued IDs, screen against sanctions lists, and maintain audit trails for AML compliance.",
  "Identity Verification":
    "Identity verification platforms confirm that users are who they claim to be by checking documents, selfies, and databases. Used in financial services, healthcare, and gig economy platforms for remote onboarding and access control.",
  "AML":
    "Anti-Money Laundering (AML) software monitors transactions, screens customers against sanctions and PEP lists, and generates Suspicious Activity Reports. Mandatory for banks, fintechs, and cryptocurrency exchanges under FATF and regional regulations.",
  "Fraud Prevention":
    "Fraud prevention platforms combine device fingerprinting, behavioral analytics, and machine learning to detect account takeover, synthetic identity fraud, and payment fraud in real time.",
};

// Blog posts relevant to each category (update as new posts are added)
const CATEGORY_BLOG_SLUGS: Record<string, string[]> = {
  "KYC Compliance": [
    "best-kyc-aml-software-2026",
    "kyc-pricing-guide-2026",
    "veriff-vs-jumio-2026",
  ],
  "AML": [
    "kyc-aml-compliance-checklist-fintech-2026",
    "best-kyc-aml-software-2026",
    "veriff-vs-jumio-2026",
  ],
  "Identity Verification": [
    "veriff-vs-jumio-2026",
    "best-kyc-aml-software-2026",
  ],
};

const { categoryName } = Astro.props;
const { slug } = Astro.params;

const [allPosts, assessments] = await Promise.all([
  getCollection("blog"),
  getCollection("assessments"),
]);
const bestForMap: Record<string, string | undefined> = Object.fromEntries(
  assessments.map(a => [a.data.vendor, a.data.bestFor ?? undefined])
);
const relatedPosts = allPosts
  .filter((p) => (CATEGORY_BLOG_SLUGS[categoryName] ?? []).includes(p.slug))
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 3);

const vendors = getVendorsByCategory(categoryName);
const description = CATEGORY_DESCRIPTIONS[categoryName] ?? "";
const metaDescription = CATEGORY_META[categoryName]?.description ?? description.slice(0, 160);
const canonicalUrl = `${siteConfig.seo.siteUrl}/categories/${slug}`;
const content = CATEGORY_CONTENT[categoryName];

const pageTitle = CATEGORY_META[categoryName]?.title ?? `Best ${categoryName} Software 2026`;
const lastUpdatedDisplay = content
  ? new Date(content.lastUpdated).toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : null;

const itemListSchema = buildItemListSchema(
  vendors,
  `${categoryName} Software`,
  siteConfig.seo.siteUrl,
);

const faqSchema = content
  ? {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: content.faq.map((item) => ({
        "@type": "Question",
        name: item.q,
        acceptedAnswer: { "@type": "Answer", text: item.a },
      })),
    }
  : null;

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "James Whitfield",
  "url": `${siteConfig.seo.siteUrl}/about`,
  "jobTitle": "KYC & Identity Verification Analyst",
};

const schemas = faqSchema
  ? [itemListSchema, faqSchema, personSchema]
  : [itemListSchema, personSchema];

const breadcrumbItems = [
  { name: "Home", url: "/" },
  { name: "Vendors", url: "/vendors" },
  { name: categoryName, url: `/categories/${slug}` },
];
---

<BaseLayout
  title={pageTitle}
  description={metaDescription}
  canonicalUrl={canonicalUrl}
  schema={schemas}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-10">
    <BreadcrumbSchema items={breadcrumbItems} />

    <div class="mt-6 mb-10">
      {lastUpdatedDisplay && (
        <div class="flex flex-wrap items-center gap-3">
          <span class="inline-flex items-center gap-2 rounded-full border border-blue-100 bg-blue-50 px-3 py-1 text-xs font-mono text-blue-700 dark:border-blue-900/40 dark:bg-blue-950/20 dark:text-blue-400">
            Updated {lastUpdatedDisplay}
          </span>
          <span class="text-xs text-zinc-500 dark:text-zinc-400">
            Reviewed by <a href="/about" class="text-blue-600 dark:text-blue-400 hover:underline">James Whitfield</a>, KYC &amp; Identity Verification Analyst
          </span>
        </div>
      )}
      <h1 class="mt-4 text-4xl md:text-5xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-100">
        Best {categoryName} Software 2026: Compare {vendors.length} Tools
      </h1>
      {content?.intro && (
        <p class="mt-5 text-lg text-zinc-700 dark:text-zinc-300 max-w-[65ch] leading-relaxed">
          {content.intro}
        </p>
      )}
      <p class="mt-4 text-base text-zinc-600 dark:text-zinc-400 max-w-[65ch] leading-relaxed">
        {CATEGORY_DESCRIPTIONS[categoryName]}
      </p>
      <p class="mt-3 text-sm text-zinc-500 dark:text-zinc-500">
        <span id="vendor-count-text">{vendors.length} {vendors.length === 1 ? "vendor" : "vendors"}</span>
        {" · "}
        <a class="text-blue-600 dark:text-blue-400 hover:underline" href={`/vendors?category=${slug}`}>
          Refine with more filters →
        </a>
      </p>
    </div>

    <CategoryQuickFilters />

    <div class="flex items-center justify-between mb-3">
      <span class="text-xs text-zinc-400 dark:text-zinc-500 select-none">Sort:</span>
      <div class="flex items-center gap-1">
        <button
          data-sort="rating"
          class="sort-btn sort-active rounded-md px-2.5 py-1 text-xs font-medium"
        >Top Rated</button>
        <button
          data-sort="name"
          class="sort-btn rounded-md px-2.5 py-1 text-xs font-medium"
        >Name A-Z</button>
      </div>
    </div>

    <div id="vendor-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {vendors.map((v) => (
        <VendorCard vendor={v} bestForSnippet={bestForMap[v.slug]} />
      ))}
    </div>

    <style>
      .sort-btn {
        color: rgb(113 113 122); /* zinc-500 */
        transition: color 0.15s, background 0.15s;
      }
      .sort-btn:hover {
        color: rgb(39 39 42); /* zinc-800 */
      }
      .sort-btn.sort-active {
        background: rgb(24 24 27); /* zinc-900 */
        color: #fff;
      }
      @media (prefers-color-scheme: dark) {
        .sort-btn {
          color: rgb(161 161 170); /* zinc-400 */
        }
        .sort-btn:hover {
          color: rgb(228 228 231); /* zinc-200 */
        }
        .sort-btn.sort-active {
          background: rgb(244 244 245); /* zinc-100 */
          color: rgb(24 24 27); /* zinc-900 */
        }
      }
    </style>

    <script>
      (function () {
        const grid = document.getElementById('vendor-grid');
        if (!grid) return;

        function sortVendors(mode: string) {
          const cards = [...grid!.querySelectorAll<HTMLElement>('[data-vendor]')];
          const featured = cards.filter(c => c.dataset.featured === 'true');
          const regular  = cards.filter(c => c.dataset.featured !== 'true');

          const comparator = mode === 'name'
            ? (a: HTMLElement, b: HTMLElement) =>
                (a.dataset.name ?? '').localeCompare(b.dataset.name ?? '')
            : (a: HTMLElement, b: HTMLElement) =>
                parseFloat(b.dataset.rating ?? '0') - parseFloat(a.dataset.rating ?? '0');

          featured.sort(comparator);
          regular.sort(comparator);
          [...featured, ...regular].forEach(c => grid!.appendChild(c));
        }

        const btns = document.querySelectorAll<HTMLButtonElement>('[data-sort]');
        btns.forEach(btn => {
          btn.addEventListener('click', () => {
            btns.forEach(b => b.classList.remove('sort-active'));
            btn.classList.add('sort-active');
            sortVendors(btn.dataset.sort!);
          });
        });
      })();
    </script>

    {content && (
      <section class="mt-12 border-t border-zinc-200 dark:border-zinc-700 pt-10 max-w-[72ch]">
        <h2 class="text-2xl font-semibold text-zinc-900 dark:text-zinc-100 mb-4">
          {content.trendsTitle}
        </h2>
        <div class="flex flex-col gap-4 text-base text-zinc-700 dark:text-zinc-300 leading-relaxed">
          {content.trendsBody.map((para) => <p>{para}</p>)}
        </div>
      </section>
    )}

    {content && (
      <section class="mt-10 max-w-[72ch]">
        <h2 class="text-2xl font-semibold text-zinc-900 dark:text-zinc-100 mb-4">
          {content.buyingCriteriaTitle}
        </h2>
        <ul class="flex flex-col gap-2 list-disc pl-5 text-base text-zinc-700 dark:text-zinc-300 leading-relaxed">
          {content.buyingCriteria.map((point) => <li set:html={point} />)}
        </ul>
        <p class="mt-4 text-sm text-zinc-500">
          Read our full <a class="text-blue-600 dark:text-blue-400 hover:underline" href="/methodology">evaluation methodology →</a>
        </p>
      </section>
    )}

    {relatedPosts.length > 0 && (
      <section class="mt-12 border-t border-zinc-200 dark:border-zinc-700 pt-10">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-xl font-semibold text-zinc-900 dark:text-zinc-100">
            Analysis & Guides
          </h2>
          <a href="/blog" class="text-sm text-blue-600 dark:text-blue-400 hover:underline">
            View all
          </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          {relatedPosts.map((post) => (
            <a
              href={`/blog/${post.slug}`}
              class="group flex flex-col gap-2 rounded-lg border border-zinc-200 dark:border-zinc-700 bg-white dark:bg-zinc-900 p-5 hover:border-blue-300 dark:hover:border-blue-700 transition-colors"
            >
              <p class="text-sm font-medium text-zinc-900 dark:text-zinc-100 leading-snug group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                {post.data.title}
              </p>
              <p class="text-xs font-mono text-zinc-400 dark:text-zinc-500">
                {new Date(post.data.pubDate).toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "short",
                  day: "numeric",
                })}
              </p>
            </a>
          ))}
        </div>
      </section>
    )}

    {content && (
      <section class="mt-12 border-t border-zinc-200 dark:border-zinc-700 pt-10 max-w-[72ch]">
        <h2 class="text-2xl font-semibold text-zinc-900 dark:text-zinc-100 mb-4">
          Frequently asked questions
        </h2>
        <div class="flex flex-col gap-2">
          {content.faq.map((item) => (
            <details class="group rounded-lg border border-zinc-200 dark:border-zinc-700 bg-white dark:bg-zinc-900 px-4 py-3">
              <summary class="flex cursor-pointer list-none items-center justify-between text-base font-medium text-zinc-900 dark:text-zinc-100">
                <span>{item.q}</span>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  class="shrink-0 transition-transform group-open:rotate-180"
                  aria-hidden="true"
                >
                  <path d="m6 9 6 6 6-6" />
                </svg>
              </summary>
              <p class="mt-3 text-base text-zinc-700 dark:text-zinc-300 leading-relaxed">
                {item.a}
              </p>
            </details>
          ))}
        </div>
      </section>
    )}

    {slug === "kyc-compliance" && (
      <div class="mt-12 p-6 rounded-xl bg-zinc-50 dark:bg-zinc-900/50 border border-zinc-200 dark:border-zinc-700">
        <h2 class="text-lg font-semibold text-zinc-900 dark:text-zinc-100 mb-2">
          Compare KYC pricing by volume
        </h2>
        <p class="text-sm text-zinc-600 dark:text-zinc-400 mb-4">
          Enter your monthly verification volume to see estimated costs across {vendors.length} vendors side by side.
        </p>
        <a
          href="/tools/kyc-cost-calculator"
          class="inline-flex items-center justify-center rounded-md px-4 py-2 text-sm font-medium bg-zinc-900 dark:bg-zinc-100 text-white dark:text-zinc-900 hover:bg-zinc-700 dark:hover:bg-zinc-300 transition-colors"
        >
          Open KYC Cost Calculator
        </a>
      </div>
    )}
  </div>
</BaseLayout>
