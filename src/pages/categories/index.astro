---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BreadcrumbSchema from "../../components/seo/BreadcrumbSchema.astro";
import { CATEGORY_SLUGS, vendors } from "../../lib/vendors";

const CATEGORY_DESCRIPTIONS: Record<string, string> = {
  "Biometric Authentication":
    "Face, fingerprint, voice, and iris verification software. Replaces passwords with hardware sensors or software-based cameras.",
  "KYC Compliance":
    "Automates identity verification during customer onboarding. Verifies government IDs, screens against sanctions lists, and maintains audit trails.",
  "Identity Verification":
    "Confirms users are who they claim to be by checking documents, selfies, and databases. Used in fintech, healthcare, and gig economy platforms.",
  "AML":
    "Monitors transactions, screens against sanctions and PEP lists, and generates Suspicious Activity Reports for banks and crypto exchanges.",
  "Fraud Prevention":
    "Combines device fingerprinting, behavioral analytics, and ML to detect account takeover and synthetic identity fraud in real time.",
};

const categoryData = Object.entries(CATEGORY_SLUGS).map(([name, slug]) => ({
  name,
  slug,
  description: CATEGORY_DESCRIPTIONS[name] ?? "",
  count: vendors.filter((v) => v.categories.includes(name)).length,
}));

const breadcrumbItems = [
  { name: "Home", url: "/" },
  { name: "Categories", url: "/categories" },
];

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Biometric Software Categories",
  numberOfItems: categoryData.length,
  itemListElement: categoryData.map((cat, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: cat.name,
    url: `https://primebiometry.com/categories/${cat.slug}`,
  })),
};
---

<BaseLayout
  title="Browse Biometric Vendors by Category (2026)"
  description="5 categories of identity tech: KYC, IDV, biometric auth, AML, fraud. Each with vendor counts, average price, and best-fit use cases. Pick the right shelf."
  canonicalUrl="https://primebiometry.com/categories"
  schema={itemListSchema}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-10">
    <BreadcrumbSchema items={breadcrumbItems} />

    <div class="mt-6 mb-10">
      <h1 class="text-4xl md:text-5xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-100">
        Browse by Category
      </h1>
      <p class="mt-4 text-base text-zinc-600 dark:text-zinc-400 max-w-[65ch] leading-relaxed">
        {vendors.length} vendors across {categoryData.length} categories. Find the right software for your use case.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {categoryData.map((cat) => (
        <a
          href={`/categories/${cat.slug}`}
          class="group flex flex-col gap-4 rounded-lg border border-zinc-200 dark:border-zinc-700 bg-white dark:bg-zinc-900 p-6 hover:border-blue-300 dark:hover:border-blue-700 transition-colors"
        >
          <div class="flex items-start justify-between gap-2">
            <h2 class="text-base font-semibold text-zinc-900 dark:text-zinc-100 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors leading-snug">
              {cat.name}
            </h2>
            <span class="shrink-0 text-xs font-mono text-zinc-400 dark:text-zinc-500 mt-0.5">
              {cat.count} vendors
            </span>
          </div>
          <p class="text-sm text-zinc-600 dark:text-zinc-400 leading-relaxed">
            {cat.description}
          </p>
          <span class="text-sm text-blue-600 dark:text-blue-400 group-hover:underline mt-auto">
            Compare {cat.name} software →
          </span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
