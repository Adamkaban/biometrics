---
import BaseLayout from "../layouts/BaseLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://primebiometry.com" },
    { "@type": "ListItem", position: 2, name: "Privacy Policy", item: "https://primebiometry.com/privacy" },
  ],
};
---

<BaseLayout
  title="Privacy Policy"
  description="PrimeBiometry privacy policy: how we collect, use, and protect your data. GDPR compliant."
  canonicalUrl="https://primebiometry.com/privacy"
  schema={schema}
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-16 md:py-24">

    <!-- Breadcrumb -->
    <nav class="mb-10" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2 text-xs text-zinc-400 dark:text-zinc-500">
        <li><a href="/" class="hover:text-zinc-600 dark:hover:text-zinc-300 transition-colors">Home</a></li>
        <li aria-hidden="true">/</li>
        <li class="text-zinc-600 dark:text-zinc-300" aria-current="page">Privacy Policy</li>
      </ol>
    </nav>

    <h1 class="text-4xl md:text-5xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-100 mb-4">
      Privacy Policy
    </h1>
    <p class="text-sm text-zinc-400 dark:text-zinc-500 mb-10">Last updated: June 1, 2026</p>

    <div class="prose-custom space-y-10 text-sm text-zinc-600 dark:text-zinc-400 leading-relaxed">

      <section>
        <h2 class="text-lg font-semibold text-zinc-900 dark:text-zinc-100 mb-3">1. Who We Are</h2>
        <p>PrimeBiometry (<a href="https://primebiometry.com" class="text-blue-600 dark:text-blue-400 hover:underline">primebiometry.com</a>) is an independent research and comparison platform for biometric authentication and identity verification software. Contact: <a href="mailto:support@primebiometry.com" class="text-blue-600 dark:text-blue-400 hover:underline">support@primebiometry.com</a></p>
      </section>

      <section>
        <h2 class="text-lg font-semibold text-zinc-900 dark:text-zinc-100 mb-3">2. What We Collect</h2>
        <p class="mb-3">We collect minimal data necessary to operate the site:</p>
        <ul class="space-y-2 list-disc list-inside">
          <li><strong class="text-zinc-700 dark:text-zinc-300">Contact form submissions</strong> via Tally.so: name, email, and message content you voluntarily provide.</li>
          <li><strong class="text-zinc-700 dark:text-zinc-300">Analytics</strong>: aggregated, anonymized page view data. No individual tracking.</li>
          <li><strong class="text-zinc-700 dark:text-zinc-300">Server logs</strong>: standard web server logs (IP address, browser, referrer) retained by Cloudflare for up to 7 days for security purposes.</li>
        </ul>
        <p class="mt-3">We do not collect biometric data, payment information, or any sensitive personal data.</p>
      </section>

      <section>
        <h2 class="text-lg font-semibold text-zinc-900 dark:text-zinc-100 mb-3">3. How We Use Your Data</h2>
        <ul class="space-y-2 list-disc list-inside">
          <li>To respond to contact form inquiries</li>
          <li>To understand how the site is used and improve content</li>
          <li>To ensure site security and prevent abuse</li>
        </ul>
        <p class="mt-3">We do not sell your data. We do not use your data for advertising targeting.</p>
      </section>

      <section>
        <h2 class="text-lg font-semibold text-zinc-900 dark:text-zinc-100 mb-3">4. Cookies</h2>
        <p>This site uses no first-party tracking cookies. Third-party services may set cookies:</p>
        <ul class="mt-3 space-y-2 list-disc list-inside">
          <li><strong class="text-zinc-700 dark:text-zinc-300">Cloudflare</strong>: security cookies (<code class="bg-zinc-100 dark:bg-zinc-800 px-1 rounded text-xs">__cf_bm</code>) for bot detection. See <a href="https://www.cloudflare.com/privacypolicy/" class="text-blue-600 dark:text-blue-400 hover:underline" rel="noopener noreferrer" target="_blank">Cloudflare Privacy Policy</a>.</li>
          <li><strong class="text-zinc-700 dark:text-zinc-300">Tally.so</strong>: contact form cookies when you interact with the contact form. See <a href="https://tally.so/privacy" class="text-blue-600 dark:text-blue-400 hover:underline" rel="noopener noreferrer" target="_blank">Tally Privacy Policy</a>.</li>
        </ul>
      </section>

      <section>
        <h2 class="text-lg font-semibold text-zinc-900 dark:text-zinc-100 mb-3">5. Affiliate Links</h2>
        <p>Some vendor links on this site are affiliate links (routed through <code class="bg-zinc-100 dark:bg-zinc-800 px-1 rounded text-xs">/go/[vendor]</code>). When you click these links and make a purchase, we may earn a commission. Affiliate relationships do not influence editorial scores or assessments. All affiliate links are marked with <code class="bg-zinc-100 dark:bg-zinc-800 px-1 rounded text-xs">rel="nofollow noopener"</code>.</p>
      </section>

      <section>
        <h2 class="text-lg font-semibold text-zinc-900 dark:text-zinc-100 mb-3">6. Third-Party Services</h2>
        <div class="overflow-x-auto">
          <table class="w-full text-sm border-collapse">
            <thead>
              <tr class="border-b border-zinc-200 dark:border-zinc-800">
                <th class="text-left py-2 pr-4 font-medium text-zinc-700 dark:text-zinc-300">Service</th>
                <th class="text-left py-2 pr-4 font-medium text-zinc-700 dark:text-zinc-300">Purpose</th>
                <th class="text-left py-2 font-medium text-zinc-700 dark:text-zinc-300">Privacy Policy</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-zinc-100 dark:divide-zinc-800">
              {[
                { service: "Cloudflare", purpose: "CDN, DNS, DDoS protection", url: "https://www.cloudflare.com/privacypolicy/" },
                { service: "Tally.so", purpose: "Contact form", url: "https://tally.so/privacy" },
              ].map((row) => (
                <tr>
                  <td class="py-2 pr-4">{row.service}</td>
                  <td class="py-2 pr-4">{row.purpose}</td>
                  <td class="py-2"><a href={row.url} class="text-blue-600 dark:text-blue-400 hover:underline" rel="noopener noreferrer" target="_blank">View</a></td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <section>
        <h2 class="text-lg font-semibold text-zinc-900 dark:text-zinc-100 mb-3">7. Your Rights (GDPR / CCPA)</h2>
        <p class="mb-3">If you are located in the EU, UK, or California, you have the right to:</p>
        <ul class="space-y-1 list-disc list-inside">
          <li>Access the personal data we hold about you</li>
          <li>Request correction or deletion of your data</li>
          <li>Object to processing of your data</li>
          <li>Request data portability</li>
        </ul>
        <p class="mt-3">To exercise any of these rights, email <a href="mailto:support@primebiometry.com" class="text-blue-600 dark:text-blue-400 hover:underline">support@primebiometry.com</a>. We will respond within 30 days.</p>
      </section>

      <section>
        <h2 class="text-lg font-semibold text-zinc-900 dark:text-zinc-100 mb-3">8. Data Retention</h2>
        <p>Contact form submissions are retained until you request deletion or for 2 years from submission, whichever comes first. Server logs are retained by Cloudflare per their policy.</p>
      </section>

      <section>
        <h2 class="text-lg font-semibold text-zinc-900 dark:text-zinc-100 mb-3">9. Changes to This Policy</h2>
        <p>We may update this policy. Material changes will be reflected in the "Last updated" date at the top. Continued use of the site after changes constitutes acceptance.</p>
      </section>

      <section>
        <h2 class="text-lg font-semibold text-zinc-900 dark:text-zinc-100 mb-3">10. Contact</h2>
        <p>Privacy questions: <a href="mailto:support@primebiometry.com" class="text-blue-600 dark:text-blue-400 hover:underline">support@primebiometry.com</a></p>
      </section>

    </div>
  </div>
</BaseLayout>
